{
  "name": "preflight",
  "version": "0.1.0",
  "description": "Fast, deterministic security preflight for AI-written TypeScript.",
  "type": "module",
  "bin": { "preflight": "./dist/cli.js" },
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check:self": "node ./scripts/check-self.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "package:smoke": "node ./scripts/package-smoke.mjs",
    "ci": "npm run typecheck && npm test && npm run build && npm run pack:dry-run && npm run package:smoke && npm run check:self"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
