{
  "name": "preflight",
  "version": "0.1.0",
  "description": "Fast, deterministic security preflight for AI-written TypeScript.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "security",
    "static-analysis",
    "typescript",
    "ai-security",
    "llm",
    "cli",
    "preflight",
    "taint-analysis",
    "developer-tools"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SHAURYAKSHARMA24/Project_EEZ.git"
  },
  "bugs": {
    "url": "https://github.com/SHAURYAKSHARMA24/Project_EEZ/issues"
  },
  "homepage": "https://github.com/SHAURYAKSHARMA24/Project_EEZ#readme",
  "bin": { "preflight": "./dist/cli.js" },
  "files": ["dist"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check:self": "node ./scripts/check-self.mjs",
    "pack:dry-run": "npm pack --dry-run",
    "package:smoke": "node ./scripts/package-smoke.mjs",
    "benchmark": "node ./scripts/benchmark.mjs",
    "benchmark:corpus": "node ./benchmark/score.mjs",
    "ci": "npm run typecheck && npm test && npm run build && npm run benchmark:corpus && npm run pack:dry-run && npm run package:smoke && npm run check:self && npm run benchmark"
  },
  "dependencies": {
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "vitest": "^3.2.6"
  }
}
